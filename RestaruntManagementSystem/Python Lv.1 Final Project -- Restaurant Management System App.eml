# Codeyoung Python Level 1 - Class 47 & 48 Final Project

# Import modules
from tkinter import *
import datetime

# Functions for submit and clear buttons
def submit():
    listbox.insert(1, order_no_entry.get())
    listbox.insert(2, fries_meal_entry.get())
    listbox.insert(3, lunch_meal_entry.get())
    listbox.insert(4, burger_meal_entry.get())
    listbox.insert(5, pizza_meal_entry.get())
    listbox.insert(6, cheese_burger_entry.get())
    listbox.insert(7, drinks_entry.get())

def clear():
    listbox.grid(row=3D11,column=3D1)
    listbox.delete(0,END)
    order_no_entry.delete(0,END)
    fries_meal_entry.delete(0,END)
    lunch_meal_entry.delete(0,END)
    burger_meal_entry.delete(0,END)
    pizza_meal_entry.delete(0,END)
    cheese_burger_entry.delete(0,END)
    drinks_entry.delete(0,END)

# Creating the Window and adding the name and setting size
window =3D Tk()
window.title("Restarunt Management System")
window.geometry("500x500")

# Adding Background color to window
window.config(bg=3D"darkgrey")

# Adding an iconphoto to the window
logo =3D PhotoImage(file=3D"appicon.png")
window.iconphoto(True,logo)

# Creating an order summary label
ordersummarylabel =3D Label(window,text=3D"Order Summary Label: ", fg=3D"bl=
ack", bg=3D"darkgrey")
ordersummarylabel.grid(row=3D11,column=3D0)

# Creating a listbox to to see how many meals you ordered
listbox =3D Listbox(window, height=3D10, width=3D20, bg=3D"white")
listbox.grid(row=3D11,column=3D1)

# App Header
header =3D Label(window, text=3D"Restarunt Management System", fg=3D"black"=
, font=3D("Arial", 12, "bold"), bg=3D"yellow")
header.grid(row=3D0,column=3D1)

# Setting Current Datetime
current_datetime =3D datetime.datetime.now()

# Adding Datetime label to display current date and time
datetime_label =3D Label(window, text=3Dcurrent_datetime, fg=3D"lightgreen"=
, bg=3D"black")
datetime_label.grid(row=3D1,column=3D1)

# Create a order number label
order_no_label =3D Label(window, text=3D"Order No.", fg=3D"black", bg=3D"li=
ghtgreen")
order_no_label.grid(row=3D2,column=3D0)

# Create a order number entry to enter the order number
order_no_entry =3D Entry(window, bg=3D"lightblue")
order_no_entry.grid(row=3D2,column=3D1)

# Create a fries meal label
fries_meal_label =3D Label(window, text=3D"Fries Meal", fg=3D"black", bg=3D=
"lightgreen")
fries_meal_label.grid(row=3D3,column=3D0)

# Create a fries meal entry to enter how many fries you want
fries_meal_entry =3D Entry(window, bg=3D"lightblue")
fries_meal_entry.grid(row=3D3,column=3D1)

# Create a lunch meal label
lunch_meal_label =3D Label(window, text=3D"Lunch Meal", fg=3D"black", bg=3D=
"lightgreen")
lunch_meal_label.grid(row=3D4,column=3D0)

# Create a lunch meal entry to enter how many lunch meals you want
lunch_meal_entry =3D Entry(window, bg=3D"lightblue")
lunch_meal_entry.grid(row=3D4,column=3D1)

# Create a burger meal label
burger_meal_label =3D Label(window, text=3D"Burger Meal", fg=3D"black", bg=
=3D"lightgreen")
burger_meal_label.grid(row=3D5,column=3D0)

# Create a burger meal entry to enter how many burger meals you want
burger_meal_entry =3D Entry(window, bg=3D"lightblue")
burger_meal_entry.grid(row=3D5,column=3D1)

# Create a pizza meal label
pizza_meal_label =3D Label(window, text=3D"Pizza Meal", fg=3D"black", bg=3D=
"lightgreen")
pizza_meal_label.grid(row=3D6,column=3D0)

# Create a pizza meal entry to enter how many pizzas meals you want
pizza_meal_entry =3D Entry(window, bg=3D"lightblue")
pizza_meal_entry.grid(row=3D6,column=3D1)

# Create a cheese burger label
cheese_burger_label =3D Label(window, text=3D"Cheese burger", fg=3D"black",=
 bg=3D"lightgreen")
cheese_burger_label.grid(row=3D7,column=3D0)

# Create a cheese burger entry to enter how many cheeseburgers meals you wa=
nt
cheese_burger_entry =3D Entry(window, bg=3D"lightblue")
cheese_burger_entry.grid(row=3D7,column=3D1)

# Create a drinks label
drinks_label =3D Label(window, text=3D"Drinks", fg=3D"black", bg=3D"lightgr=
een")
drinks_label.grid(row=3D8,column=3D0)

# Create a drinks entry to enter how many drinks you want
drinks_entry =3D Entry(window, bg=3D"lightblue")
drinks_entry.grid(row=3D8,column=3D1)

# Add a submit button to submit the quantity of your meals
